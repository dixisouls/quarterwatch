# ── Database ─────────────────────────────
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/quarterwatch
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/quarterwatch

# ── Auth ─────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Google OAuth ──────────────────────────
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Cloud Tasks ───────────────────────────
# For local dev, point to the emulator
CLOUD_TASKS_EMULATOR_HOST=tasks:8123
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1
CLOUD_TASKS_QUEUE=quarterwatch-jobs

# ── Cloud Storage ─────────────────────────
# For local dev this is unused in Phase 1
GCS_BUCKET_NAME=quarterwatch-transcripts

# ── External APIs ─────────────────────────
# Get a free key at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your-fmp-api-key

# Alpha Vantage free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# ── CORS ─────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Environment ───────────────────────────
ENVIRONMENT=development
